class Nameroute < Formula
  desc "Local TCP L7 Router - Name it. We route it."
  homepage "https://github.com/SpreadWorks/name-route"
  version "%%VERSION%%"
  license "MIT"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/SpreadWorks/name-route/releases/download/v%%VERSION%%/nameroute-aarch64-apple-darwin"
      sha256 "%%SHA256_MACOS_ARM64%%"
    else
      url "https://github.com/SpreadWorks/name-route/releases/download/v%%VERSION%%/nameroute-x86_64-apple-darwin"
      sha256 "%%SHA256_MACOS_X86_64%%"
    end
  end

  on_linux do
    if Hardware::CPU.arm?
      url "https://github.com/SpreadWorks/name-route/releases/download/v%%VERSION%%/nameroute-aarch64-unknown-linux-musl"
      sha256 "%%SHA256_LINUX_ARM64%%"
    else
      url "https://github.com/SpreadWorks/name-route/releases/download/v%%VERSION%%/nameroute-x86_64-unknown-linux-musl"
      sha256 "%%SHA256_LINUX_X86_64%%"
    end
  end

  def install
    binary = Dir.glob("nameroute*").first
    mv binary, "nameroute" if binary != "nameroute"
    bin.install "nameroute"
  end

  service do
    run [opt_bin/"nameroute", "serve"]
    keep_alive true
    log_path var/"log/nameroute.log"
    error_log_path var/"log/nameroute.log"
  end

  test do
    assert_match "nameroute", shell_output("#{bin}/nameroute --help")
  end
end
